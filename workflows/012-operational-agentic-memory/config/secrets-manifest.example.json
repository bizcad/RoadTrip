{
  "$comment": "EXAMPLE ONLY — this file is checked into source control for reference. It contains NO secret values. In practice, encrypt this as secrets-manifest.enc using scripts/encrypt-manifest.py before committing.",

  "examples": [
    {
      "$comment": "--- LEGAL BOT ---",
      "bot_id": "legal-bot",
      "version": "1.0.0",
      "secrets": [
        {
          "app_name": "westlaw",
          "key": "WESTLAW_API_KEY",
          "required": true,
          "scopes": ["case-law-search", "document-retrieval"],
          "description": "Westlaw Edge API key for US federal and state case law search. Required for primary research workflow.",
          "rotation_days": 90
        },
        {
          "app_name": "anthropic",
          "key": "ANTHROPIC_API_KEY",
          "required": true,
          "scopes": ["llm-inference"],
          "description": "Anthropic API key for LLM-backed legal reasoning and document summarization.",
          "rotation_days": 90
        },
        {
          "app_name": "courtlistener",
          "key": "COURTLISTENER_TOKEN",
          "required": false,
          "scopes": ["public-case-law-fallback"],
          "description": "CourtListener API token for free public case law fallback when Westlaw is unavailable. Optional — degraded mode only.",
          "rotation_days": 365
        }
      ],
      "blocked": [
        "TWITTER_BEARER_TOKEN",
        "LINKEDIN_CLIENT_SECRET",
        "BUFFER_API_KEY"
      ]
    },

    {
      "$comment": "--- MARKETING BOT ---",
      "bot_id": "marketing-bot",
      "version": "1.0.0",
      "secrets": [
        {
          "app_name": "twitter",
          "key": "TWITTER_BEARER_TOKEN",
          "required": true,
          "scopes": ["social-media-post", "analytics-read"],
          "description": "Twitter/X OAuth 2.0 Bearer Token for publishing posts and reading engagement analytics.",
          "rotation_days": 90
        },
        {
          "app_name": "linkedin",
          "key": "LINKEDIN_CLIENT_SECRET",
          "required": true,
          "scopes": ["social-media-post"],
          "description": "LinkedIn API client secret for organization page posting.",
          "rotation_days": 90
        },
        {
          "app_name": "buffer",
          "key": "BUFFER_API_KEY",
          "required": false,
          "scopes": ["scheduled-post"],
          "description": "Buffer API key for scheduling cross-platform posts. Optional — used when real-time posting is not required.",
          "rotation_days": 180
        }
      ],
      "blocked": [
        "WESTLAW_API_KEY",
        "COURTLISTENER_TOKEN"
      ]
    }
  ]
}
